{
  "compilerOptions": {
    "types": ["node"],
    "target": "ES2024",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "lib": ["ES2024", "DOM"],
    "noEmit": true
  },
  "include": ["src/**/*.ts"]
}
